{
  "expo": {
    "name": "Deukway",
    "slug": "deukway",
    "version": "1.0.0",
    "scheme": "deukway",
    "orientation": "portrait",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sn.deukway.app"
    },
    "android": {
      "package": "sn.deukway.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Deukway accède à vos photos.",
          "cameraPermission": "Deukway utilise la caméra."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "464bd9e2-a81f-4554-84f3-18ceb455d9ac"
      }
    }
  }
}
